# Copy this file to `application.properties` (which is gitignored).
# Secret values go in `application-local.properties` (also gitignored).

spring.application.name=medix-backend

# Database
spring.datasource.url=jdbc:postgresql://localhost:5432/medimind
spring.datasource.username=postgres

# JPA/Hibernate
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.open-in-view=false

# JWT (secret lives in application-local.properties)
jwt.expiration=86400000

# AI Config (API key lives in application-local.properties)
ai.api.url=https://api.groq.com/openai/v1/chat/completions

# Server
server.port=8080

# Logging
logging.level.com.medimind=DEBUG

# Load local properties (secrets)
spring.profiles.active=local

# File Uploads
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
file.upload-dir=uploads/health-records
dashboard.upload-dir=uploads/dashboard-reports
